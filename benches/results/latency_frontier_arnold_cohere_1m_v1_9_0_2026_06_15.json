{
  "benchmark": "pg_turbovec vs pgvector HNSW \u2014 AVX2 latency frontier",
  "host": {
    "name": "arnold",
    "cpu": "12th Gen Intel(R) Core(TM) i9-12900H",
    "arch": "x86_64",
    "logical_cpus": 20,
    "simd": [
      "avx2",
      "fma"
    ],
    "avx512": false,
    "ram_gib": 31,
    "os": "Fedora 44 (Linux 7.0.11-200.fc44.x86_64, glibc 2.43)",
    "note": "Busy shared workstation (interactive desktop + other agent sessions + Discord/Firefox)."
  },
  "build": {
    "pg_turbovec": "v1.9.0",
    "git": "e2d49cf",
    "turbovec_fork": "d3d468e (v0.9.0)",
    "pgrx": "0.17.0",
    "postgresql": "17.9",
    "pgvector": "0.8.0",
    "openblas": "/usr/lib64/libopenblas.so.0 (0.3.29, Fedora)",
    "release": true,
    "rustflags": "-L /scratch/pg_turbovec-bench/lib -C linker=/usr/bin/cc"
  },
  "corpus": {
    "name": "Cohere wikipedia 1M x 1024-d (cosine, L2-normalized)",
    "rows": 1000000,
    "dim": 1024,
    "held_out_queries": 1000,
    "gt": "brute-force exact top-10 by cosine (gt_top10.npy, computed on meh)",
    "comparability": "Parquet shards 0000-0010 scp'd from meh, md5-verified identical. GT/query npys byte-identical to the meh run. In-DB brute-force seqscan top-10 == gt_top10.npy on 5 probe queries (overlap@10=1.00, top-1 exact). Same near-dup structure as meh (9996/10000 distinct in first 10k)."
  },
  "isolation": {
    "method": "postmaster started under `taskset -c 2-5` (dedicated P-cores of the i9-12900H, away from cores 0-1 favored by the kernel/IRQs and the E-cores 14-19); all backends inherit the CPU mask. The python sweep driver also pinned to 2-5. Dedicated bench cluster on port 28815 / socket /scratch/pg_turbovec-bench \u2014 does NOT touch the user's other postmasters or processes.",
    "scheduling": "default nice (negative nice needs privilege; CPU pinning is the main lever per the isolation plan \u2014 insulate, do not preempt the user).",
    "shared_buffers": "2GB (RAM-constrained host)",
    "contention_measurement": "per-batch: /proc/loadavg (1m before+after), /proc/stat CPU busy/iowait/steal delta, free+available RAM. Per-query >3x-median outliers flagged; both raw and outlier-filtered p50/p95/p99 plus a 5% trimmed mean reported. contended_flag set if observed 1m load > 1.5.",
    "warm_protocol": "20 warmup queries (pgvector) / 5 warmup queries (turbovec full-scan) untimed to warm the per-backend Arc cache + OS page cache, then timed.",
    "n_timed": {
      "pgvector_hnsw": 400,
      "turbovec": 40
    },
    "latency_basis": "server-side Execution Time from EXPLAIN (ANALYZE) for BOTH engines (fair engine-to-engine; excludes client RTT)."
  },
  "correctness_gate": {
    "test": "10k x 128-d distinct unit vectors, turbovec 4-bit, 20 held-out probes",
    "avx2_path": true,
    "mean_recall_at_10": 1.0,
    "all_top10_distinct": true,
    "result": "PASS",
    "note": "Confirms the AVX2 SIMD kernel (not meh's scalar fallback) is correct on v1.9.0."
  },
  "storage": {
    "heap_total_mb": 5332,
    "indexes": [
      {
