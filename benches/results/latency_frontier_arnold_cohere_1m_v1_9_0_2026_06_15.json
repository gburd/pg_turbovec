        "bytes": 537280512,
        "vs_hnsw": "15.2x smaller"
      }
    ],
    "note": "Byte-for-byte identical to the meh run (CPU-independent). 7.6x / 15.2x confirmed."
  },
  "build_times": {
    "pgvector_hnsw": "17:55 (m=16, efc=64, maintenance_work_mem=2GB w/ disk spill)",
    "pg_turbovec_4bit": "01:37",
    "pg_turbovec_2bit": "01:23",
    "note": "Build times not directly comparable to meh: arnold used maintenance_work_mem=2GB (RAM-constrained) vs meh's 8GB, so HNSW spilled to disk and took longer. turbovec builds are AVX2-accelerated here. Storage sizes ARE comparable and match meh."
  },
